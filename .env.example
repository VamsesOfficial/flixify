# ════════════════════════════════════════════════
#  FLIXIFY — Environment Variables
#  Copy ke: .env.local  (development)
#           Vercel Dashboard > Settings > Environment Variables  (production)
# ════════════════════════════════════════════════

# ── Firebase (Client SDK) ─────────────────────
# Ambil dari: Firebase Console > Project Settings > Your Apps > Config
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Midtrans (client-side Snap.js) ───────────────
# Ambil dari: Midtrans Dashboard > Settings > Access Keys
# Sandbox  → starts with SB-Mid-client-
# Production → starts with Mid-client-
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
VITE_MIDTRANS_IS_PRODUCTION=false

# ── App URL (untuk Midtrans callback) ─────────────
# Development:
VITE_APP_URL=http://localhost:5173
# Production (ganti setelah deploy ke Vercel):
# VITE_APP_URL=https://flixify.vercel.app

# ════════════════════════════════════════════════
#  SERVER-SIDE ONLY (Vercel Serverless Functions)
#  Jangan prefix VITE_ — tidak boleh expose ke browser
# ════════════════════════════════════════════════

# ── Midtrans Server Key ────────────────────────
# Sandbox  → starts with SB-Mid-server-
# Production → starts with Mid-server-
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ── Firebase Admin SDK ─────────────────────────
# Ambil dari: Firebase Console > Project Settings > Service Accounts
#             > Generate new private key  (download JSON)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste private_key dari JSON (termasuk -----BEGIN/END-----, newline sebagai \n)
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----\n"
